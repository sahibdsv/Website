{
  "hosting": {
    "target": "v2",
    "public": ".",
    "ignore": [
      "firebase.json",
      "AGENTS.md",
      "firebase-debug.log",
      ".git/**",
      ".firebase/**",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
