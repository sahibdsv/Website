{
  "hosting": [
    {
      "target": "v1",
      "public": ".",
      "ignore": [
        "firebase.json",
        "AGENTS.md",
        "firebase-debug.log",
        ".git/**",
        ".firebase/**",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "v2",
      "public": ".",
      "ignore": [
        "firebase.json",
        "AGENTS.md",
        "firebase-debug.log",
        ".git/**",
        ".firebase/**",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|js|css|mp4|glb|gltf|geojson|gpx)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=31536000"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
