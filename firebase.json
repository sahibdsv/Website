{
  "hosting": [
    {
      "target": "v1",
      "public": ".",
      "ignore": [
        "firebase.json",
        "AGENTS.md",
        "firebase-debug.log",
        ".git/**",
        ".firebase/**",
        "**/.*",
        "**/node_modules/**",
        "tools/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "v2",
      "public": ".",
      "ignore": [
        "firebase.json",
        "AGENTS.md",
        "firebase-debug.log",
        ".git/**",
        ".firebase/**",
        "**/.*",
        "**/node_modules/**",
        "**/run.bat"
      ],
      "headers": [
        {
          "source": "/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
